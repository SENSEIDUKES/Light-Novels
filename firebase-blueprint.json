{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "activePortraitId": { "type": "string", "description": "ID of the selected account-owned cultivator portrait." },
        "preferredLanguage": { "type": "string" },
        "defaultTranslationLanguage": { "type": "string" },
        "savedStoryCount": { "type": "number" },
        "activeStories": { "type": "array" },
        "inactiveStories": { "type": "array" },
        "joinedDate": { "type": "string" },
        "updatedAt": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "admin", "user"] }
      },
      "required": ["uid", "username", "joinedDate", "updatedAt"]
    },
    "CultivatorPortraitAsset": {
      "title": "Cultivator Portrait Asset",
      "description": "A durable, account-owned portrait and its future-facing visual customization metadata.",
      "type": "object",
      "properties": {
        "schemaVersion": { "type": "number", "enum": [1] },
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "storagePath": { "type": "string" },
        "mimeType": { "type": "string", "enum": ["image/jpeg", "image/png", "image/webp"] },
        "source": { "type": "string", "enum": ["generated"] },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "generation": {
          "type": "object",
          "properties": {
            "prompt": { "type": "string" },
            "description": { "type": "string" },
            "daoRank": { "type": "string" },
            "daoXp": { "type": "number" },
            "powerStage": { "type": "string" },
            "equippedArtifactId": { "type": ["string", "null"] },
            "usedReferenceImage": { "type": "boolean" }
          },
          "required": ["prompt", "description", "daoRank", "daoXp", "powerStage", "equippedArtifactId", "usedReferenceImage"]
        },
        "customization": {
          "type": "object",
          "properties": {
            "frameId": { "type": ["string", "null"] },
            "glowId": { "type": ["string", "null"] },
            "bannerId": { "type": ["string", "null"] },
            "effectIds": { "type": "array", "items": { "type": "string" } }
          },
          "required": ["frameId", "glowId", "bannerId", "effectIds"]
        }
      },
      "required": [
        "schemaVersion", "id", "userId", "imageUrl", "storagePath", "mimeType", "source",
        "createdAt", "updatedAt", "generation", "customization"
      ]
    },
    "StoryWorld": {
      "title": "Story World",
      "description": "A novel's story world, containing chapters, memory, and settings. Belongs to a specific user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The user ID of the author." },
        "id": { "type": "string" },
        "title": { "type": "string" },
        "genre": { "type": "string" },
        "mcName": { "type": "string" },
        "customPremise": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "memory": { "$ref": "#/entities/StoryMemory" },
        "arcs": { "$ref": "#/entities/StoryArcs" },
        "currentChapterNumber": { "type": "number" },
        "imageUrl": { "type": "string" },
        "imageHistory": { "type": "array" },
        "intake": { "$ref": "#/entities/IntakeData" },
        "blueprint": { "$ref": "#/entities/WorldBlueprint" },
        "relationships": { "type": "array" },
        "karmaNodes": { "type": "array" },
        "readerPreferences": { "type": "object" },
        "bookmarks": { "type": "array" }
      },
      "required": ["userId", "id", "title", "genre", "mcName", "customPremise", "createdAt", "updatedAt", "currentChapterNumber"]
    },
    "StoryMemory": {
      "title": "Story Memory",
      "description": "Story state tracking",
      "type": "object",
      "properties": {}
    },
    "StoryArcs": {
      "title": "Story Arcs List",
      "description": "Array of story arcs",
      "type": "array",
      "properties": {}
    },
    "Chapter": {
      "title": "Story Chapter",
      "description": "A single chapter content.",
      "type": "object",
      "properties": {}
    },
    "IntakeData": {
      "title": "Intake Data",
      "description": "Intake forms",
      "type": "object",
      "properties": {
        "storyTags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Custom selected and defined story tags"
        }
      }
    },
    "WorldBlueprint": {
      "title": "World Blueprint",
      "description": "World building",
      "type": "object",
      "properties": {}
    },
    "LoreGlossary": {
      "title": "Lore Glossary",
      "description": "Glossary for translating original terms to target language",
      "type": "object",
      "properties": {
        "novel_id": { "type": "string" },
        "source_text": { "type": "string" },
        "target_text": { "type": "string" },
        "target_lang": { "type": "string" }
      },
      "required": ["novel_id", "source_text", "target_text", "target_lang"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "#/entities/UserProfile",
      "description": "User profiles containing public and preference data."
    },
    "users/{userId}/portraits/{portraitId}": {
      "schema": "#/entities/CultivatorPortraitAsset",
      "description": "Private durable cultivator portrait assets owned by the parent user."
    },
    "stories/{storyId}": {
      "schema": "#/entities/StoryWorld",
      "description": "Stories belonging to users."
    },
    "stories/{storyId}/chapters/{chapterId}": {
      "schema": "#/entities/Chapter",
      "description": "Individual chapters belonging to a story."
    },
    "lore_glossary/{termId}": {
      "schema": "#/entities/LoreGlossary",
      "description": "Glossary terms used for translation within novels."
    }
  }
}
