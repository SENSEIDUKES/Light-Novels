# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DEEPL_AUTH_KEY: Required for native chapter translation via the DeepL API.
DEEPL_AUTH_KEY=""

# AI_TEMPERATURE: Optional temperature override for text generation (e.g., 0.95)
AI_TEMPERATURE=""

# AI_MAX_TOKENS: Optional maximum output tokens limit for text generation (e.g., 8192)
AI_MAX_TOKENS=""

# Cloudflare R2 Storage Configuration
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
# Private bucket for permanent user media. Keep public access and r2.dev disabled.
R2_PRIVATE_BUCKET_NAME="celestial-library-private-media"
# Existing public/catalog bucket. R2_BUCKET_NAME remains a compatibility fallback.
R2_PUBLIC_BUCKET_NAME="library"
R2_BUCKET_NAME=""
R2_ENDPOINT_URL=""
R2_PUBLIC_BASE_URL="https://library.seihouse.org"
R2_PUBLIC_LIBRARY_URL="https://library.seihouse.org"
R2_PUBLIC_AUDIO_URL="https://celestialaudio.seihouse.org"
R2_PUBLIC_IMAGES_URL="https://celestialimages.seihouse.org"
R2_PUBLIC_VIDEOS_URL="https://celestialvideos.seihouse.org"
R2_PUBLIC_DEV_URL="https://pub-1dc6dce66c5e4322b2b73fe92f331dbc.r2.dev"
AWS_REGION="auto"

# Phase-two persistence/media cutover (server-only).
# FIREBASE_SERVICE_ACCOUNT_JSON must be a single-line service-account JSON
# secret in hosted environments. Never prefix these values with VITE_.
FIREBASE_PROJECT_ID="seihouse-moduel"
FIREBASE_SERVICE_ACCOUNT_JSON=""

# Comma-separated HTTPS hosts from which the server may ingest temporary
# provider media. Redirect destinations must also be included.
MEDIA_REMOTE_SOURCE_HOSTS="image.pollinations.ai"

# Maximum SQL cleanup tasks processed by one maintenance invocation.
MEDIA_CLEANUP_BATCH_SIZE="100"
