rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'username', 'joinedDate', 'updatedAt'])
        && data.uid is string && data.uid.size() <= 128
        && data.username is string && data.username.size() <= 100
        && data.joinedDate is string && data.joinedDate.size() <= 40
        && data.updatedAt is string && data.updatedAt.size() <= 40
        && (!('qi' in data) || data.qi is number)
        && (!('dao_xp' in data) || data.dao_xp is number)
        && (!('dao_rank' in data) || data.dao_rank is string)
        && (!('displayNameColor' in data) || (data.displayNameColor is string && data.displayNameColor.size() <= 30))
        && data.uid == request.auth.uid;
    }

    function isValidDaoXpEvent(data) {
      return data.keys().hasAll(['user_id', 'event_type', 'xp_amount', 'created_at'])
        && data.user_id is string && data.user_id.size() <= 128
        && data.event_type is string && data.event_type.size() <= 50
        && data.xp_amount is number
        && data.created_at is string && data.created_at.size() <= 40
        && (!('source_id' in data) || data.source_id == null || data.source_id is string)
        && (!('source_type' in data) || data.source_type == null || data.source_type is string)
        && data.user_id == request.auth.uid;
    }

    function isValidStoryWorld(data) {
      return data.keys().hasAll(['userId', 'id', 'title', 'genre', 'mcName', 'customPremise', 'createdAt', 'updatedAt', 'currentChapterNumber'])
        && data.userId is string && data.userId.size() <= 128
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 500
        && data.genre is string && data.genre.size() <= 100
        && data.mcName is string && data.mcName.size() <= 100
        && data.customPremise is string && data.customPremise.size() <= 50000
        && data.createdAt is string && data.createdAt.size() <= 40
        && data.updatedAt is string && data.updatedAt.size() <= 40
        && data.currentChapterNumber is number
        && data.userId == request.auth.uid;
    }

    function isValidChapter(data) {
      return data.keys().hasAll(['storyId', 'chapterNumber'])
        && data.storyId is string && data.storyId.size() <= 128
        && data.chapterNumber is number;
    }

    function isValidLoreGlossary(data) {
      return data.keys().hasAll(['novel_id', 'source_text', 'target_text', 'target_lang'])
        && data.keys().size() == 4
        && data.novel_id is string && data.novel_id.size() <= 128
        && data.source_text is string && data.source_text.size() <= 500
        && data.target_text is string && data.target_text.size() <= 500
        && data.target_lang is string && data.target_lang.size() <= 20;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && userId == request.auth.uid;
      allow create: if isSignedIn() 
        && isValidId(userId) 
        && incoming().uid == userId
        && isValidUserProfile(incoming());
      
      allow update: if isSignedIn()
        && isValidId(userId)
        && existing().uid == request.auth.uid
        && incoming().uid == existing().uid
        && incoming().joinedDate == existing().joinedDate
        && isValidUserProfile(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['username', 'displayName', 'displayNameColor', 'avatarUrl', 'preferredLanguage', 'defaultTranslationLanguage', 'savedStoryCount', 'activeStories', 'inactiveStories', 'updatedAt', 'qi', 'dao_xp', 'dao_rank'])
        && (!('updatedAt' in incoming().diff(existing()).affectedKeys()) || (incoming().updatedAt is string && incoming().updatedAt.size() <= 40));
    }

    match /dao_xp_events/{eventId} {
      allow read: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() 
        && isValidDaoXpEvent(incoming());
    }

    match /stories/{storyId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(storyId) 
        && incoming().id == storyId
        && isValidStoryWorld(incoming());
        // In real update, we check diff, but for 'stories' there are many fields, some optional (arcs, logic, etc.).
        // We will allow partial update that preserves userId and uses valid story world or has explicit fields.
        // For flexibility of this novel app, let's say owner can update.
        // The prompt says: "The All-or-Nothing Rule: When validating updates with affectedKeys().hasOnly(), it must explicitly declare exactly the allowed fields for that action."
        
      allow update: if isSignedIn()
        && isValidId(storyId)
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().id == existing().id
        && incoming().createdAt == existing().createdAt
        && (
            isValidStoryWorld(incoming()) // Must remain structurally valid
        )
        && incoming().diff(existing()).affectedKeys().hasOnly([
          'title', 'genre', 'mcName', 'customPremise', 'updatedAt', 'currentChapterNumber', 
          'imageUrl', 'intake', 'blueprint', 'relationships', 'karmaNodes', 'readerPreferences', 
          'bookmarks', 'memory', 'arcs', 'parentStoryId', 'forkChapterNumber', 'imageHistory', 
          'lastImageChapter', 'evolutionReady', 'evolutionReason', 'availableVisualUpdate'
        ])
        && (!('title' in incoming().diff(existing()).affectedKeys()) || (incoming().title is string && incoming().title.size() <= 500))
        && (!('updatedAt' in incoming().diff(existing()).affectedKeys()) || (incoming().updatedAt is string && incoming().updatedAt.size() <= 40));

      allow delete: if isSignedIn() && isValidId(storyId) && existing().userId == request.auth.uid;

      match /chapters/{chapterId} {
        allow read: if isSignedIn() && get(/databases/$(database)/documents/stories/$(storyId)).data.userId == request.auth.uid;
        
        allow create: if isSignedIn()
          && isValidId(chapterId)
          && get(/databases/$(database)/documents/stories/$(storyId)).data.userId == request.auth.uid
          && isValidChapter(incoming())
          && incoming().storyId == storyId;
          
        allow update: if isSignedIn()
          && isValidId(chapterId)
          && get(/databases/$(database)/documents/stories/$(storyId)).data.userId == request.auth.uid
          && incoming().storyId == existing().storyId
          && incoming().chapterNumber == existing().chapterNumber
          && (isValidChapter(incoming()))
          && incoming().diff(existing()).affectedKeys().hasOnly(['generatedContent', 'blocks', 'summary', 'statsChangeMessage', 'cuePayload', 'translations', 'updatedAt', 'revisionId']);
          
        allow delete: if isSignedIn() && isValidId(chapterId) && get(/databases/$(database)/documents/stories/$(storyId)).data.userId == request.auth.uid;
      }
    }
    match /lore_glossary/{termId} {
      allow read: if isSignedIn() && (
        get(/databases/$(database)/documents/stories/$(resource.data.novel_id)).data.userId == request.auth.uid
      );
      
      allow create: if isSignedIn()
        && isValidId(termId)
        && isValidLoreGlossary(incoming())
        && exists(/databases/$(database)/documents/stories/$(incoming().novel_id))
        && get(/databases/$(database)/documents/stories/$(incoming().novel_id)).data.userId == request.auth.uid;
        
      allow update: if isSignedIn()
        && isValidId(termId)
        && existing().novel_id == incoming().novel_id
        && isValidLoreGlossary(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['source_text', 'target_text', 'target_lang'])
        && get(/databases/$(database)/documents/stories/$(existing().novel_id)).data.userId == request.auth.uid;

      allow delete: if isSignedIn() 
        && isValidId(termId) 
        && get(/databases/$(database)/documents/stories/$(existing().novel_id)).data.userId == request.auth.uid;
    }
  }
}
