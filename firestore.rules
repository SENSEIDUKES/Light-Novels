rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner() {
      return isSignedIn() && (
        request.auth.token.email == 'amaurylindy@gmail.com' ||
        request.auth.token.email == 'seihouseproductions@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'owner')
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        isOwner() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin')
      );
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'username'])
        && data.uid is string && data.uid.size() <= 128
        && data.username is string && data.username.size() <= 100
        && (!('role' in data) || (data.role is string && (data.role == 'owner' || data.role == 'admin' || data.role == 'user')))
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100))
        && (!('displayNameColor' in data) || (data.displayNameColor is string && data.displayNameColor.size() <= 30))
        && (!('avatarUrl' in data) || (data.avatarUrl is string && data.avatarUrl.size() <= 1000))
        && (!('activePortraitId' in data) || isValidId(data.activePortraitId))
        && (!('preferredLanguage' in data) || (data.preferredLanguage is string && data.preferredLanguage.size() <= 50))
        && (!('defaultTranslationLanguage' in data) || (data.defaultTranslationLanguage is string && data.defaultTranslationLanguage.size() <= 50))
        && (!('joinedDate' in data) || (data.joinedDate is string && data.joinedDate.size() <= 40))
        && (!('updatedAt' in data) || (data.updatedAt is string && data.updatedAt.size() <= 40))
        && (!('qi' in data) || data.qi is number)
        && (!('dao_xp' in data) || data.dao_xp is number)
        && (!('dao_rank' in data) || data.dao_rank is string)
        && (!('heavenly_qi' in data) || data.heavenly_qi is number)
        && (!('sect_qi' in data) || data.sect_qi is number)
        && (!('demonic_qi' in data) || data.demonic_qi is number)
        && (!('premiumTier' in data) || (data.premiumTier is string && data.premiumTier.size() <= 50))
        && (!('imageGenerationCount' in data) || data.imageGenerationCount is number)
        && (!('imageQuotaResetAt' in data) || (data.imageQuotaResetAt is string && data.imageQuotaResetAt.size() <= 40))
        && (!('writingStreak' in data) || data.writingStreak is number)
        && (!('lastSessionEnd' in data) || (data.lastSessionEnd is string && data.lastSessionEnd.size() <= 40))
        && (!('daoPillarStreak' in data) || data.daoPillarStreak is number)
        && (!('daoPillarCracked' in data) || data.daoPillarCracked is bool)
        && (!('lastReadDate' in data) || (data.lastReadDate is string && data.lastReadDate.size() <= 40))
        && (!('lastInteractionDate' in data) || (data.lastInteractionDate is string && data.lastInteractionDate.size() <= 40))
        && (!('equippedArtifactId' in data) || (data.equippedArtifactId == null || (data.equippedArtifactId is string && data.equippedArtifactId.size() <= 128)))
        && (!('activeStatusEffects' in data) || data.activeStatusEffects is list)
        && (!('cosmicInventory' in data) || data.cosmicInventory is list)
        && (!('inventory' in data) || data.inventory is list)
        && (data.uid == request.auth.uid || isOwner());
    }

    function hasValidPortraitStoragePath(data, userId, portraitId) {
      return (
        data.mimeType == 'image/jpeg'
        && (
          data.storagePath == 'users/' + userId + '/portraits/' + portraitId + '.jpg'
          || data.storagePath == 'users/' + userId + '/portraits/' + portraitId + '.jpeg'
        )
      ) || (
        data.mimeType == 'image/png'
        && data.storagePath == 'users/' + userId + '/portraits/' + portraitId + '.png'
      ) || (
        data.mimeType == 'image/webp'
        && data.storagePath == 'users/' + userId + '/portraits/' + portraitId + '.webp'
      );
    }

    function isValidPortraitEffectIds(effectIds) {
      return effectIds is list
        && effectIds.size() <= 8
        && (effectIds.size() < 1 || isValidId(effectIds[0]))
        && (effectIds.size() < 2 || isValidId(effectIds[1]))
        && (effectIds.size() < 3 || isValidId(effectIds[2]))
        && (effectIds.size() < 4 || isValidId(effectIds[3]))
        && (effectIds.size() < 5 || isValidId(effectIds[4]))
        && (effectIds.size() < 6 || isValidId(effectIds[5]))
        && (effectIds.size() < 7 || isValidId(effectIds[6]))
        && (effectIds.size() < 8 || isValidId(effectIds[7]));
    }

    function isValidPortraitCustomization(customization) {
      return customization is map
        && customization.keys().hasAll(['frameId', 'glowId', 'bannerId', 'effectIds'])
        && customization.keys().hasOnly(['frameId', 'glowId', 'bannerId', 'effectIds'])
        && (customization.frameId == null || isValidId(customization.frameId))
        && (customization.glowId == null || isValidId(customization.glowId))
        && (customization.bannerId == null || isValidId(customization.bannerId))
        && isValidPortraitEffectIds(customization.effectIds);
    }

    function isValidPortraitGeneration(generation) {
      return generation is map
        && generation.keys().hasAll([
          'prompt', 'description', 'daoRank', 'daoXp', 'powerStage',
          'equippedArtifactId', 'usedReferenceImage'
        ])
        && generation.keys().hasOnly([
          'prompt', 'description', 'daoRank', 'daoXp', 'powerStage',
          'equippedArtifactId', 'usedReferenceImage'
        ])
        && generation.prompt is string && generation.prompt.size() <= 5000
        && generation.description is string && generation.description.size() <= 2000
        && generation.daoRank is string && generation.daoRank.size() <= 100
        && generation.daoXp is number && generation.daoXp >= 0
        && generation.powerStage is string && generation.powerStage.size() <= 200
        && (
          generation.equippedArtifactId == null
          || (generation.equippedArtifactId is string && generation.equippedArtifactId.size() <= 128)
        )
        && generation.usedReferenceImage is bool;
    }

    function isValidPortraitAsset(data, userId, portraitId) {
      return data.keys().hasAll([
          'schemaVersion', 'id', 'userId', 'imageUrl', 'storagePath', 'mimeType',
          'source', 'createdAt', 'updatedAt', 'generation', 'customization'
        ])
        && data.keys().hasOnly([
          'schemaVersion', 'id', 'userId', 'imageUrl', 'storagePath', 'mimeType',
          'source', 'createdAt', 'updatedAt', 'generation', 'customization'
        ])
        && data.schemaVersion is int && data.schemaVersion == 1
        && data.id == portraitId && isValidId(data.id)
        && data.userId == userId && isValidId(data.userId)
        && data.imageUrl is string && data.imageUrl.size() > 0 && data.imageUrl.size() <= 4096
        && data.storagePath is string && data.storagePath.size() <= 512
        && (
          data.mimeType == 'image/jpeg'
          || data.mimeType == 'image/png'
          || data.mimeType == 'image/webp'
        )
        && hasValidPortraitStoragePath(data, userId, portraitId)
        && data.source == 'generated'
        && data.createdAt is string && data.createdAt.size() > 0 && data.createdAt.size() <= 40
        && data.updatedAt is string && data.updatedAt.size() > 0 && data.updatedAt.size() <= 40
        && isValidPortraitGeneration(data.generation)
        && isValidPortraitCustomization(data.customization);
    }

    function isOptionalSeedText(data, fieldName, maxLength) {
      return !(fieldName in data)
        || (data[fieldName] is string && data[fieldName].size() <= maxLength);
    }

    function isValidSeedStringList(value, maxItems) {
      return value is list && value.size() <= maxItems;
    }

    function isValidSeedIntake(data) {
      return data is map
        && data.keys().hasOnly([
          'novelTitle', 'mcName', 'genrePath', 'corePremise', 'desiredPlotDirection',
          'storyTags', 'destinedEnding', 'estimatedArcs', 'worldType', 'startingLocation',
          'societyStructure', 'dangerLevel', 'generalAtmosphere', 'startingIdentity',
          'personality', 'mainFlaw', 'secretAdvantage', 'startingWeakness', 'moralAlignment',
          'mcBio', 'customCharacters', 'customFactions', 'startingPowerConcept', 'powerFlavor',
          'powerPace', 'knownRanks', 'uniquePath', 'longTermGoal', 'firstMajorConflict',
          'mainAntagonistPressure', 'romanceLevel', 'faceSlappingLevel', 'comedyLevel',
          'tournamentArcPreference', 'haremPreference', 'betrayalLevel', 'thingsToAvoid',
          'mustIncludeElements', 'hardcoreFateMode', 'fatePressure', 'makeItWorkInstruction'
        ])
        // Firestore limits a rule evaluation to 1,000 expressions. Validate
        // the core generation-bearing text fields here; the exact key whitelist
        // above and client normalizer keep the remaining private guidance fields
        // data-only without weakening an authorization boundary.
        && isOptionalSeedText(data, 'novelTitle', 500)
        && isOptionalSeedText(data, 'mcName', 500)
        && isOptionalSeedText(data, 'genrePath', 500)
        && isOptionalSeedText(data, 'corePremise', 50000)
        && isOptionalSeedText(data, 'desiredPlotDirection', 50000)
        && isOptionalSeedText(data, 'startingPowerConcept', 50000)
        && isOptionalSeedText(data, 'makeItWorkInstruction', 50000)
        && (!('storyTags' in data) || isValidSeedStringList(data.storyTags, 100))
        && (!('customCharacters' in data) || (data.customCharacters is list && data.customCharacters.size() <= 100))
        && (!('customFactions' in data) || (data.customFactions is list && data.customFactions.size() <= 100))
        && (!('estimatedArcs' in data) || (data.estimatedArcs is int && data.estimatedArcs > 0 && data.estimatedArcs <= 1000))
        && (!('hardcoreFateMode' in data) || data.hardcoreFateMode is bool)
        && (!('fatePressure' in data) || (
          data.fatePressure == 'Relaxed'
          || data.fatePressure == 'Balanced'
          || data.fatePressure == 'Hardcore'
          || data.fatePressure == 'Dao Master'
        ));
    }

    function isValidSeedBlueprint(data) {
      return data is map
        && data.keys().hasAll([
          'title', 'logline', 'worldOverview', 'startingLocation', 'societyStructure',
          'powerSystemOutline', 'mcProfile', 'majorFactions', 'initialCharacters',
          'majorMysteries', 'firstArcPromise', 'tropeRules', 'styleBible',
          'estimatedArcs', 'unresolvedPlotThreads'
        ])
        && data.keys().hasOnly([
          'title', 'logline', 'worldOverview', 'startingLocation', 'societyStructure',
          'powerSystemOutline', 'mcProfile', 'majorFactions', 'initialCharacters',
          'majorMysteries', 'firstArcPromise', 'tropeRules', 'styleBible',
          'destinedEnding', 'estimatedArcs', 'unresolvedPlotThreads'
        ])
        && data.title is string && data.title.size() > 0 && data.title.size() <= 500
        && data.logline is string && data.logline.size() <= 50000
        && data.worldOverview is string && data.worldOverview.size() <= 50000
        && data.startingLocation is string && data.startingLocation.size() <= 50000
        && data.societyStructure is string && data.societyStructure.size() <= 50000
        && data.powerSystemOutline is string && data.powerSystemOutline.size() <= 50000
        && data.mcProfile is string && data.mcProfile.size() <= 50000
        && data.firstArcPromise is string && data.firstArcPromise.size() <= 50000
        && data.tropeRules is string && data.tropeRules.size() <= 50000
        && data.styleBible is string && data.styleBible.size() <= 50000
        && isOptionalSeedText(data, 'destinedEnding', 50000)
        && isValidSeedStringList(data.majorFactions, 100)
        && isValidSeedStringList(data.initialCharacters, 100)
        && isValidSeedStringList(data.majorMysteries, 100)
        && isValidSeedStringList(data.unresolvedPlotThreads, 100)
        && data.estimatedArcs is int && data.estimatedArcs > 0 && data.estimatedArcs <= 1000;
    }

    function isValidStorySeed(data, userId, seedId) {
      return data.keys().hasAll([
          'schemaVersion', 'id', 'userId', 'title', 'intake', 'blueprint', 'createdAt', 'updatedAt'
        ])
        && data.keys().hasOnly([
          'schemaVersion', 'id', 'userId', 'title', 'intake', 'blueprint', 'createdAt', 'updatedAt'
        ])
        && data.schemaVersion is int && data.schemaVersion == 1
        && data.id == seedId && isValidId(data.id)
        && data.userId == userId && isValidId(data.userId)
        && data.title is string && data.title.size() > 0 && data.title.size() <= 500
        && data.createdAt is string && data.createdAt.size() > 0 && data.createdAt.size() <= 40
        && data.updatedAt is string && data.updatedAt.size() > 0 && data.updatedAt.size() <= 40
        && isValidSeedIntake(data.intake)
        && isValidSeedBlueprint(data.blueprint);
    }

    function storySourceSeedExists(data) {
      return !('sourceSeedId' in data) || (
        isValidId(data.sourceSeedId)
        && exists(/databases/$(database)/documents/users/$(data.userId)/seeds/$(data.sourceSeedId))
      );
    }

    function isValidDaoXpEvent(data) {
      return data.keys().hasAll(['user_id', 'event_type', 'xp_amount', 'created_at'])
        && data.user_id is string && data.user_id.size() <= 128
        && data.event_type is string && data.event_type.size() <= 50
        && data.xp_amount is number
        && data.created_at is string && data.created_at.size() <= 40
        && (!('source_id' in data) || data.source_id == null || data.source_id is string)
        && (!('source_type' in data) || data.source_type == null || data.source_type is string)
        && data.user_id == request.auth.uid;
    }

    function isValidStoryWorld(data) {
      return data.keys().hasAll(['userId', 'id'])
        && data.userId is string && data.userId.size() <= 128
        && data.id is string && data.id.size() <= 128
        && (!('title' in data) || (data.title is string && data.title.size() <= 500))
        && (!('genre' in data) || (data.genre is string && data.genre.size() <= 100))
        && (!('mcName' in data) || (data.mcName is string && data.mcName.size() <= 100))
        && (!('customPremise' in data) || (data.customPremise is string && data.customPremise.size() <= 50000))
        && (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() <= 40))
        && (!('updatedAt' in data) || (data.updatedAt is string && data.updatedAt.size() <= 40))
        && (!('syncRevision' in data) || (data.syncRevision is string && data.syncRevision.size() <= 128))
        && (!('sourceSeedId' in data) || isValidId(data.sourceSeedId))
        && (!('conflictResolvedAt' in data) || (data.conflictResolvedAt is string && data.conflictResolvedAt.size() <= 40))
        && (!('currentChapterNumber' in data) || data.currentChapterNumber is number)
        && (!('isEdited' in data) || data.isEdited is bool)
        && (!('deleted' in data) || data.deleted is bool)
        && data.userId == request.auth.uid;
    }

    function isMinimalStoryTombstone(data, storyId) {
      return data.keys().hasOnly(['id', 'userId', 'deleted', 'updatedAt'])
        && data.id == storyId
        && data.deleted == true
        && data.updatedAt is string
        && data.updatedAt.size() <= 40;
    }

    function isValidChapter(data) {
      return data.keys().hasAll(['storyId', 'chapterNumber'])
        && data.storyId is string && data.storyId.size() <= 128
        && data.chapterNumber is number
        && (!('syncRevision' in data) || (data.syncRevision is string && data.syncRevision.size() <= 128))
        && (!('userId' in data) || (data.userId is string && data.userId.size() <= 128));
    }

    function isValidLoreGlossary(data) {
      return data.keys().hasAll(['novel_id', 'source_text', 'target_text', 'target_lang'])
        && data.novel_id is string && data.novel_id.size() <= 128
        && data.source_text is string && data.source_text.size() <= 500
        && data.target_text is string && data.target_text.size() <= 500
        && data.target_lang is string && data.target_lang.size() <= 20
        && (!('id' in data) || (data.id is string && data.id.size() <= 128));
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && isAdmin();
      allow create: if isSignedIn() 
        && isValidId(userId) 
        && incoming().uid == userId
        && isValidUserProfile(incoming());
      
      allow update: if isSignedIn()
        && isValidId(userId)
        && (
          (
            userId == request.auth.uid
            && existing().get('uid', '') == request.auth.uid
            && incoming().get('uid', '') == existing().get('uid', '')
            && incoming().get('joinedDate', '') == existing().get('joinedDate', '')
            && (!('role' in incoming()) || ('role' in existing() && incoming().role == existing().get('role', 'user')) || (!('role' in existing()) && incoming().role == 'user'))
            && isValidUserProfile(incoming())
            && incoming().diff(existing()).affectedKeys().hasOnly([
              'username', 'displayName', 'displayNameColor', 'avatarUrl', 'preferredLanguage', 
              'defaultTranslationLanguage', 'savedStoryCount', 'activeStories', 'inactiveStories', 
              'updatedAt', 'qi', 'dao_xp', 'dao_rank', 'heavenly_qi', 'sect_qi', 'demonic_qi', 
              'premiumTier', 'imageGenerationCount', 'imageQuotaResetAt', 'writingStreak', 
              'lastSessionEnd', 'daoPillarStreak', 'daoPillarCracked', 'lastReadDate', 
              'lastInteractionDate', 'cosmicInventory', 'inventory', 'equippedArtifactId', 
              'activeStatusEffects', 'activePortraitId', 'role'
            ])
          ) || (
            isOwner()
            && incoming().get('uid', '') == existing().get('uid', '')
            && incoming().get('joinedDate', '') == existing().get('joinedDate', '')
            && isValidUserProfile(incoming())
            && incoming().diff(existing()).affectedKeys().hasOnly([
              'role', 'premiumTier', 'heavenly_qi', 'sect_qi', 'username', 'displayName', 'updatedAt'
            ])
          )
        );

      match /portraits/{portraitId} {
        allow read: if isSignedIn() && userId == request.auth.uid;

        allow create: if isSignedIn()
          && userId == request.auth.uid
          && isValidId(portraitId)
          && isValidPortraitAsset(incoming(), userId, portraitId);

        allow update: if isSignedIn()
          && userId == request.auth.uid
          && existing().get('userId', '') == request.auth.uid
          && isValidId(portraitId)
          && isValidPortraitAsset(incoming(), userId, portraitId)
          && incoming().get('schemaVersion', 0) == existing().get('schemaVersion', 0)
          && incoming().get('id', '') == existing().get('id', '')
          && incoming().get('userId', '') == existing().get('userId', '')
          && incoming().get('storagePath', '') == existing().get('storagePath', '')
          && incoming().get('mimeType', '') == existing().get('mimeType', '')
          && incoming().get('source', '') == existing().get('source', '')
          && incoming().get('createdAt', '') == existing().get('createdAt', '')
          && incoming().get('generation', {}) == existing().get('generation', {})
          && incoming().get('imageUrl', '') == existing().get('imageUrl', '')
          && incoming().diff(existing()).affectedKeys().hasOnly(['customization', 'updatedAt']);

        allow delete: if isSignedIn()
          && userId == request.auth.uid
          && existing().get('userId', '') == request.auth.uid;
      }

      match /seeds/{seedId} {
        allow read: if isSignedIn() && userId == request.auth.uid;

        allow create: if isSignedIn()
          && userId == request.auth.uid
          && isValidId(seedId)
          && isValidStorySeed(incoming(), userId, seedId);

        allow update: if isSignedIn()
          && userId == request.auth.uid
          && existing().get('userId', '') == request.auth.uid
          && isValidId(seedId)
          && isValidStorySeed(incoming(), userId, seedId)
          && incoming().get('schemaVersion', 0) == existing().get('schemaVersion', 0)
          && incoming().get('id', '') == existing().get('id', '')
          && incoming().get('userId', '') == existing().get('userId', '')
          && incoming().get('createdAt', '') == existing().get('createdAt', '')
          && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'intake', 'blueprint', 'updatedAt']);

        allow delete: if isSignedIn()
          && userId == request.auth.uid
          && existing().get('userId', '') == request.auth.uid;
      }
    }

    match /dao_xp_events/{eventId} {
      allow read: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() 
        && isValidDaoXpEvent(incoming());
    }

    match /stories/{storyId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() 
        && isValidId(storyId) 
        && incoming().id == storyId
        && isValidStoryWorld(incoming())
        && storySourceSeedExists(incoming());
        
      allow update: if isSignedIn()
        && isValidId(storyId)
        && (existing().get('userId', '') == request.auth.uid || isAdmin())
        && incoming().get('userId', '') == existing().get('userId', '')
        && incoming().get('id', '') == existing().get('id', '')
        && (!('createdAt' in existing()) || !('createdAt' in incoming()) || incoming().createdAt == existing().get('createdAt', ''))
        // A normal merge write may maintain a tombstone, but it must never
        // revive one. Restoration requires an explicit delete/create flow.
        && (existing().get('deleted', false) != true || incoming().get('deleted', false) == true)
        && (
          // Deletion replaces the full story with a content-free marker. This
          // intentionally removes arbitrary historical fields, so it has its
          // own strict shape instead of the normal update allowlist.
          isMinimalStoryTombstone(incoming(), storyId)
          || (
            isValidStoryWorld(incoming())
            && incoming().diff(existing()).affectedKeys().hasOnly([
              'title', 'genre', 'mcName', 'customPremise', 'updatedAt', 'syncRevision', 'currentChapterNumber',
              'imageUrl', 'intake', 'blueprint', 'sourceSeedId', 'relationships', 'karmaNodes', 'readerPreferences',
              'bookmarks', 'memory', 'arcs', 'parentStoryId', 'forkChapterNumber', 'imageHistory',
              'lastImageChapter', 'evolutionReady', 'evolutionReason', 'availableVisualUpdate',
              'isEdited', 'userId', 'hardcoreFateMode', 'fatePressure', 'lastReadChapter',
              'lastReadScrollPosition', 'lastReadAt', 'deleted', 'readingStats', 'createdAt',
              'assignedRevealBackdrops', 'motionCoverActive', 'conflictResolvedAt',
              'readingAnchor', 'chapterGenerationBatch'
            ])
            && (!('title' in incoming().diff(existing()).affectedKeys()) || (incoming().title is string && incoming().title.size() <= 500))
            && (!('updatedAt' in incoming().diff(existing()).affectedKeys()) || (incoming().updatedAt is string && incoming().updatedAt.size() <= 40))
            && (
              !incoming().diff(existing()).affectedKeys().hasAny(['sourceSeedId'])
              || (!('sourceSeedId' in existing()) && storySourceSeedExists(incoming()))
            )
          )
        );

      // Story documents are durable deletion markers. Removing one would let a
      // stale client recreate the story and reattach any legacy orphan chapters.
      allow delete: if false;

      match /chapters/{chapterId} {
        allow read: if isSignedIn() && (
          isAdmin() || (
            exists(/databases/$(database)/documents/stories/$(storyId))
            && get(/databases/$(database)/documents/stories/$(storyId)).data.userId == request.auth.uid
            // Transitional fallback for legacy untagged chapters. Tagged
            // chapters never inherit ownership from a newly claimed parent.
            && (!('userId' in existing()) || existing().userId == request.auth.uid)
          )
        );
        
        allow create: if isSignedIn()
          && isValidId(chapterId)
          && get(/databases/$(database)/documents/stories/$(storyId)).data.userId == request.auth.uid
          && get(/databases/$(database)/documents/stories/$(storyId)).data.get('deleted', false) != true
          && isValidChapter(incoming())
          && incoming().storyId == storyId
          && incoming().userId == request.auth.uid;
          
        allow update: if isSignedIn()
          && isValidId(chapterId)
          && (get(/databases/$(database)/documents/stories/$(storyId)).data.userId == request.auth.uid || isAdmin())
          && get(/databases/$(database)/documents/stories/$(storyId)).data.get('deleted', false) != true
          && incoming().get('storyId', '') == existing().get('storyId', '')
          && incoming().get('chapterNumber', -1) == existing().get('chapterNumber', -1)
          && (!('userId' in incoming()) || incoming().userId == get(/databases/$(database)/documents/stories/$(storyId)).data.userId)
          && (
            ('userId' in existing() && incoming().get('userId', '') == existing().userId)
            || (!('userId' in existing()) && (
              !('userId' in incoming())
              || incoming().userId == get(/databases/$(database)/documents/stories/$(storyId)).data.userId
            ))
          )
          && (isValidChapter(incoming()))
          && incoming().diff(existing()).affectedKeys().hasOnly(['generatedContent', 'blocks', 'archivedBlocks', 'summary', 'episodicSummary', 'statsChangeMessage', 'cuePayload', 'contextManifest', 'translations', 'audioManifest', 'updatedAt', 'revisionId', 'syncRevision', 'syncStatus', 'imageUrl', 'userId']);
          
        allow delete: if isSignedIn() && isValidId(chapterId) && (
          isAdmin() || (
            exists(/databases/$(database)/documents/stories/$(storyId))
            && get(/databases/$(database)/documents/stories/$(storyId)).data.userId == request.auth.uid
            && (!('userId' in existing()) || existing().userId == request.auth.uid)
          )
        );
      }
    }
    match /lore_glossary/{termId} {
      allow read: if isSignedIn() && (
        get(/databases/$(database)/documents/stories/$(resource.data.novel_id)).data.userId == request.auth.uid
      );
      
      allow create: if isSignedIn()
        && isValidId(termId)
        && isValidLoreGlossary(incoming())
        && exists(/databases/$(database)/documents/stories/$(incoming().novel_id))
        && get(/databases/$(database)/documents/stories/$(incoming().novel_id)).data.userId == request.auth.uid;
        
      allow update: if isSignedIn()
        && isValidId(termId)
        && existing().get('novel_id', '') == incoming().get('novel_id', '')
        && isValidLoreGlossary(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['source_text', 'target_text', 'target_lang'])
        && get(/databases/$(database)/documents/stories/$(existing().get('novel_id', ''))).data.userId == request.auth.uid;

      allow delete: if isSignedIn() 
        && isValidId(termId) 
        && get(/databases/$(database)/documents/stories/$(existing().get('novel_id', ''))).data.userId == request.auth.uid;
    }
  }
}
